# KPIs General Balance
# ---------------------------------------------------------------------------

def kpi_general(df: pd.DataFrame) -> dict:
    """KPIs principaux de la balance générale."""
    nb_comptes       = len(df)
    nb_actifs        = len(df[df["solde_debit"] > 0])
    nb_passifs       = len(df[df["solde_credit"] > 0])
    total_mvt_debit  = df["mvt_debit"].sum()
    total_mvt_credit = df["mvt_credit"].sum()
    total_solde_debit  = df["solde_debit"].sum()
    total_solde_credit = df["solde_credit"].sum()
    equilibre        = abs(total_solde_debit - total_solde_credit) < 1000  # tolérance arrondi

    return {
        "nb_comptes":          nb_comptes,
        "nb_actifs":           nb_actifs,
        "nb_passifs":          nb_passifs,
        "total_mvt_debit":     total_mvt_debit,
        "total_mvt_credit":    total_mvt_credit,
        "total_solde_debit":   total_solde_debit,
        "total_solde_credit":  total_solde_credit,
        "equilibre":           equilibre,
        "ecart_equilibre":     total_solde_debit - total_solde_credit,
    }


def balance_par_classe(df: pd.DataFrame) -> pd.DataFrame:
    """Soldes agrégés par classe de comptes."""
    grp = df.groupby("classe").agg(
        nb_comptes   = ("num_compte", "count"),
        mvt_debit    = ("mvt_debit",  "sum"),
        mvt_credit   = ("mvt_credit", "sum"),
        solde_debit  = ("solde_debit",  "sum"),
        solde_credit = ("solde_credit", "sum"),
        solde_net    = ("solde_net",    "sum"),
    ).reset_index()
    grp["mvt_net"] = grp["mvt_debit"] - grp["mvt_credit"]
    return grp.sort_values("solde_net", key=abs, ascending=False)


def top_comptes_mouvement(df: pd.DataFrame, n: int = 15) -> pd.DataFrame:
    """Top N comptes par volume de mouvements."""
    df = df.copy()
    df["mvt_total"] = df["mvt_debit"] + df["mvt_credit"]
    return df.sort_values("mvt_total", ascending=False).head(n)[
        ["num_compte", "description", "classe", "mvt_debit", "mvt_credit", "mvt_net", "solde_net"]
    ]


def comptes_par_classe(df: pd.DataFrame, classe: str) -> pd.DataFrame:
    """Filtrer les comptes d'une classe spécifique."""
    return df[df["classe"] == classe].sort_values("solde_net", key=abs, ascending=False)


# ---------------------------------------------------------------------------
# FLAGS General Balance
# ---------------------------------------------------------------------------

def flag_comptes_desequilibres(df: pd.DataFrame, seuil: float = 1.0) -> pd.DataFrame:
    """
    Comptes où solde_net ne correspond pas à solde_debit - solde_credit.
    Peut indiquer une erreur de reporting ou d'arrondi significatif.
    """
    df = df.copy()
    df["solde_calcule"] = df["solde_debit"] - df["solde_credit"]
    df["ecart"] = (df["solde_net"] - df["solde_calcule"]).abs()
    mask = df["ecart"] > seuil
    return df[mask][["num_compte", "description", "classe", "solde_debit",
                     "solde_credit", "solde_net", "solde_calcule", "ecart"]].sort_values("ecart", ascending=False)


def flag_comptes_solde_inhabituel(df: pd.DataFrame) -> pd.DataFrame:
    """
    Comptes avec sens de solde inhabituel :
    - Comptes de charges (6x) avec solde créditeur → produit exceptionnel ou erreur
    - Comptes de produits (7x) avec solde débiteur → charge exceptionnelle ou erreur
    - Comptes de trésorerie (5x) avec solde créditeur → découvert bancaire
    """
    flags = []

    charges_crediteurs = df[
        (df["num_compte"].str.startswith("6")) & (df["solde_net"] < 0)
    ].copy()
    charges_crediteurs["anomalie"] = "Compte de charge à solde créditeur"
    flags.append(charges_crediteurs)

    produits_debiteurs = df[
        (df["num_compte"].str.startswith("7")) & (df["solde_net"] > 0)
    ].copy()
    produits_debiteurs["anomalie"] = "Compte de produit à solde débiteur"
    flags.append(produits_debiteurs)

    tresorerie_creditrice = df[
        (df["num_compte"].str.startswith("5")) &
        (df["solde_credit"] > 0) & (df["solde_debit"] == 0)
    ].copy()
    tresorerie_creditrice["anomalie"] = "Trésorerie à solde créditeur (découvert)"
    flags.append(tresorerie_creditrice)

    if not any(not f.empty for f in flags):
        return pd.DataFrame()

    result = pd.concat([f for f in flags if not f.empty], ignore_index=True)
    cols = ["num_compte", "description", "classe", "solde_debit", "solde_credit",
            "solde_net", "anomalie"]
    return result[[c for c in cols if c in result.columns]]


def flag_comptes_sans_mouvement(df: pd.DataFrame) -> pd.DataFrame:
    """Comptes avec solde N-1 non nul mais aucun mouvement sur la période."""
    mask = (
        (df["n1_solde"].abs() > 0) &
        (df["mvt_debit"] == 0) &
        (df["mvt_credit"] == 0)
    )
    return df[mask][["num_compte", "description", "classe", "n1_solde", "solde_net"]].sort_values(
        "n1_solde", key=abs, ascending=False
    )


def flag_variation_significative(df_ref: pd.DataFrame, df_cmp: pd.DataFrame,
                                  annee_ref: str, annee_cmp: str,
                                  seuil_pct: float = 50.0) -> pd.DataFrame:
    """
    Comptes avec variation de solde > seuil_pct% entre deux années.
    Utile pour identifier des anomalies YoY.
    """
    ref = df_ref[["num_compte", "description", "solde_net"]].rename(
        columns={"solde_net": f"solde_{annee_ref}"}
    )
    cmp = df_cmp[["num_compte", "solde_net"]].rename(
        columns={"solde_net": f"solde_{annee_cmp}"}
    )
    merged = ref.merge(cmp, on="num_compte", how="inner")

    merged["variation_pct"] = (
        (merged[f"solde_{annee_cmp}"] - merged[f"solde_{annee_ref}"]) /
        merged[f"solde_{annee_ref}"].replace(0, pd.NA).abs() * 100
    ).fillna(0).round(1)

    mask = merged["variation_pct"].abs() > seuil_pct
    return merged[mask].sort_values("variation_pct", key=abs, ascending=False)


def resume_flags_general(df: pd.DataFrame) -> dict:
    """Résumé de tous les flags."""
    return {
        "nb_desequilibres":         len(flag_comptes_desequilibres(df)),
        "nb_soldes_inhabituels":     len(flag_comptes_solde_inhabituel(df)),
        "nb_sans_mouvement":         len(flag_comptes_sans_mouvement(df)),
    }